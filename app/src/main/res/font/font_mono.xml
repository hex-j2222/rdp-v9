<?xml version="1.0" encoding="utf-8"?>
<!--
    "Share Tech Mono" — console/HUD-style monospace used for small labels,
    latency readouts, etc (issue #7). See font_display.xml for replacement
    instructions; same approach applies here.

    Download (OFL licensed):
      https://fonts.google.com/specimen/Share+Tech+Mono
    File to replace:
      res/font/share_tech_mono.ttf    <- Share Tech Mono Regular (weight 400)
-->
<font-family xmlns:android="http://schemas.android.com/apk/res/android">
    <font
        android:fontStyle="normal"
        android:fontWeight="400"
        android:font="@font/share_tech_mono" />
</font-family>
