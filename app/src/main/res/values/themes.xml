<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!--
        Compose apps only need a minimal XML Activity theme.
        Theme.AppCompat.DayNight.NoActionBar is always available via
        appcompat (transitive through activity-compose / hilt-navigation-compose).
        All real theming is done in Compose via HexRDPTheme.
    -->
    <style name="Theme.HexRDP" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/deep_space</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <!--
            BUG-COMPAT-3 FIX: tools:targetApi was "27" but android:windowLayoutInDisplayCutoutMode
            was introduced in API 28 (Android 9). Using targetApi="27" causes lint to suppress
            API-28 warnings incorrectly, masking real issues on API-27 devices where this
            attribute is silently ignored (no cutout handling, content may be clipped).
            Fix: use targetApi="28" which is the actual API level this attribute requires.
        -->
        <item name="android:windowLayoutInDisplayCutoutMode" tools:targetApi="28">shortEdges</item>
        <item name="android:enforceStatusBarContrast" tools:targetApi="29">false</item>
        <item name="android:enforceNavigationBarContrast" tools:targetApi="29">false</item>

        <!--
            Splash screen attributes (issue #5 — avoid theme flash on restart).
            On API 31+, installSplashScreen() reads these directly from the
            activity theme. windowSplashScreenBackground matches the app's
            dark background so the splash never looks like a "different app"
            flashing before HexRDPTheme takes over, regardless of which
            theme/dark-mode the user previously saved.
        -->
        <item name="android:windowSplashScreenBackground" tools:targetApi="31">@color/deep_space</item>
    </style>

    <style name="Theme.HexRDP.Session" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/deep_space</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowFullscreen">true</item>
        <!--
            BUG-COMPAT-3 FIX (Session theme): Same wrong targetApi="27" as the main theme.
            Additionally, the value "always" was only added in API 30 (Android 11) — even later
            than the attribute itself (API 28). Using targetApi="27" masked both issues.
            Fix: use targetApi="30" which is the actual minimum API that supports "always".
        -->
        <item name="android:windowLayoutInDisplayCutoutMode" tools:targetApi="30">always</item>
        <item name="android:enforceStatusBarContrast" tools:targetApi="29">false</item>
        <item name="android:enforceNavigationBarContrast" tools:targetApi="29">false</item>
    </style>
</resources>
