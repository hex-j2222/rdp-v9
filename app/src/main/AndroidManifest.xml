<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- ── Storage / File Transfer ──────────────────────────────────────────── -->
    <!-- READ_EXTERNAL_STORAGE: API 26-32 (Android 8–12L) for phone file browser -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <!-- WRITE_EXTERNAL_STORAGE: API 26-28 (Android 8–9) for saving downloaded files -->
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />
    <!-- READ_MEDIA_* : API 33+ (Android 13+) granular media permissions -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission android:name="android.permission.READ_MEDIA_VIDEO" />
    <uses-permission android:name="android.permission.READ_MEDIA_AUDIO" />
    <!-- MANAGE_EXTERNAL_STORAGE: grants access to ALL files (user opted-in via Settings).
         Required for browsing non-media folders (Documents, Downloads, APKs, etc.).
         App will request this gracefully with a Settings redirect if needed. -->
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE"
        tools:ignore="ScopedStorage" />

    <!-- ── Network ──────────────────────────────────────────────────────────── -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <!-- Bug #8 FIX: Required to prevent Android WiFi driver from filtering UDP
         broadcast packets used by Wake-on-LAN. Without this lock, Magic Packets
         are silently dropped on most WiFi adapters. -->
    <uses-permission android:name="android.permission.CHANGE_WIFI_MULTICAST_STATE" />
    <!-- BUG-08: Removed CHANGE_NETWORK_STATE — no code in the app calls any
         API that requires it. Its presence unnecessarily enlarged the attack
         surface and flagged in Play Store security reviews. -->

    <!-- ── Input / Haptic ───────────────────────────────────────────────────── -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- ── Screen awake during session ─────────────────────────────────────── -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- ── Notifications (Android 13+ POST_NOTIFICATIONS required at runtime) ─ -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- ── Foreground service for background RDP session ───────────────────── -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CONNECTED_DEVICE" />

    <!-- ── Receive boot for auto-reconnect (future) ─────────────────────────── -->
    <!-- ✅ قفل البصمة -->
    <uses-permission android:name="android.permission.USE_BIOMETRIC" />
    <!--
        BUG 12 FIX: Removed USE_FINGERPRINT — deprecated since API 28.
        androidx.biometric does not require it; its presence triggers
        unnecessary security warnings in Play Store reviews.
    -->

    <application
        android:name=".HexRDPApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.HexRDP"
        android:localeConfig="@xml/locales_config"
        android:largeHeap="true"
        android:hardwareAccelerated="true"
        tools:targetApi="36">

        <!-- ── Main Activity ──────────────────────────────────────────────── -->
        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize"
            android:configChanges="orientation|screenSize|smallestScreenSize|screenLayout|keyboardHidden|density|fontScale"
            android:screenOrientation="unspecified"
            android:enableOnBackInvokedCallback="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- Open .rdp files from file managers / email / browser -->
            <!-- BUG #4 FIX: Added BROWSABLE category so the app is offered when the user
                 opens an .rdp link from a web browser. Without it, browser intents are
                 silently filtered out since the system requires BROWSABLE for web-originated
                 VIEW intents (https://developer.android.com/guide/components/intents-filters#browser). -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="content" android:mimeType="application/x-rdp" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="file" android:mimeType="application/x-rdp" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="content" android:mimeType="*/*" android:pathPattern=".*\.rdp" />
            </intent-filter>
        </activity>

        <!-- ── RDP Session Activity (immersive full-screen) ───────────────── -->
        <activity
            android:name=".ui.screens.RdpSessionActivity"
            android:exported="false"
            android:launchMode="standard"
            android:windowSoftInputMode="adjustResize"
            android:configChanges="orientation|screenSize|smallestScreenSize|screenLayout|keyboardHidden|density|fontScale"
            android:screenOrientation="unspecified"
            android:enableOnBackInvokedCallback="true"
            android:theme="@style/Theme.HexRDP.Session" />

        <!-- ── Background Session Foreground Service ──────────────────────── -->
        <service
            android:name=".ui.screens.RdpSessionService"
            android:exported="false"
            android:foregroundServiceType="connectedDevice" />

    </application>

</manifest>
